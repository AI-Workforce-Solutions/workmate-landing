</section>

<script>
  type Asset = { name: string; browser_download_url: string; size: number }
  type Release = { name: string; tag_name: string; published_at: string; assets: Asset[] }

  const REPOS = {
    opencode: "AI-Workforce-Solutions/workmate-releases",
    openclaw: "AI-Workforce-Solutions/crawbot-mike",
  }

  const OS_PATTERNS = {
    mac: [/mac/i, /darwin/i, /dmg$/i],
    win: [/win/i, /windows/i, /\.exe$/i, /\.msi$/i],
    linux: [/linux/i, /appimage$/i, /\.deb$/i, /\.rpm$/i],
  }

  function detectOS(): "mac" | "win" | "linux" | null {
    const ua = navigator.userAgent.toLowerCase()
    if (ua.includes("mac")) return "mac"
    if (ua.includes("win")) return "win"
    if (ua.includes("linux")) return "linux"
    return null
  }

  function detectArch(): "arm64" | "x64" {
    const ua = navigator.userAgent.toLowerCase()
    if (ua.includes("arm64") || ua.includes("aarch64")) return "arm64"
    if (navigator.userAgent.includes("Mac") && (navigator as any).userAgentData?.architecture === "arm") return "arm64"
    return "x64"
  }

  function pickAsset(assets: Asset[], os: "mac" | "win" | "linux", arch: "arm64" | "x64"): Asset | null {
    const osPatterns = OS_PATTERNS[os]
    const osCandidates = assets.filter((a) => osPatterns.some((p) => p.test(a.name)))
    if (osCandidates.length === 0) return null

    const archPat = arch === "arm64" ? /(arm64|aarch64)/i : /(x64|x86[_-]?64|amd64)/i
    const archMatch = osCandidates.find((a) => archPat.test(a.name))
    if (archMatch) return archMatch

    const installer = osCandidates.find((a) => !/(blockmap|\.yml|\.json)$/i.test(a.name))
    return installer ?? osCandidates[0]
  }

  function formatDate(iso: string): string {
    const d = new Date(iso)
    return d.toLocaleDateString("vi-VN", { year: "numeric", month: "2-digit", day: "2-digit" })
  }

  async function hydrate(key: keyof typeof REPOS) {
    const repo = REPOS[key]
    const cacheKey = `dl-${key}`
    const cacheTtl = 5 * 60 * 1000

    let release: Release | null = null
    const cached = localStorage.getItem(cacheKey)
    if (cached) {
      try {
        const { ts, data } = JSON.parse(cached)
        if (Date.now() - ts < cacheTtl) release = data
      } catch {}
    }

    if (!release) {
      try {
        const res = await fetch(`https://api.github.com/repos/${repo}/releases/latest`)
        if (!res.ok) throw new Error(`HTTP ${res.status}`)
        release = await res.json()
        localStorage.setItem(cacheKey, JSON.stringify({ ts: Date.now(), data: release }))
      } catch (e) {
        const versionEl = document.querySelector(`[data-download-version="${key}"]`)
        if (versionEl) versionEl.textContent = "—"
        return
      }
    }

    if (!release) return

    const versionEl = document.querySelector(`[data-download-version="${key}"]`)
    if (versionEl) {
      versionEl.innerHTML = `
        <div class="font-mono font-semibold text-gray-700">${release.tag_name}</div>
        <div>${formatDate(release.published_at)}</div>
      `
    }

    const os = detectOS()
    const arch = detectArch()
    const targetEl = document.querySelector(`[data-download-target="${key}"] [data-default-cta]`) as HTMLAnchorElement | null
    if (os && targetEl) {
      const asset = pickAsset(release.assets, os, arch)
      if (asset) {
        targetEl.href = asset.browser_download_url
        const osLabel = { mac: "macOS", win: "Windows", linux: "Linux" }[os]
        const variantLabel = key === "opencode" ? "OpenCode" : "OpenClaw"
        const span = targetEl.querySelector("span")
        if (span) span.textContent = `Tải bản ${variantLabel} cho ${osLabel}`
      }
    }

    const allEl = document.querySelector(`[data-download-all="${key}"]`)
    if (allEl) {
      const osLinks = allEl.querySelectorAll("a")
      const osMap: Array<"mac" | "win" | "linux"> = ["mac", "win", "linux"]
      osLinks.forEach((link, i) => {
        const asset = pickAsset(release!.assets, osMap[i], arch)
        if (asset) link.setAttribute("href", asset.browser_download_url)
      })
    }
  }

  hydrate("opencode")
  hydrate("openclaw")
</script>
