---

<section id="download" class="bg-white py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">Tải về</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Sản phẩm của AI Workforce Solutions
      </h2>
      <p class="mt-4 text-lg text-gray-600">
        Chọn bản cài phù hợp với hệ điều hành của bạn. Hoàn toàn miễn phí cho cá nhân.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      <!-- Workmate AI -->
      <article class="rounded-2xl border-2 border-brand-600 bg-gradient-to-br from-white to-brand-50/30 p-8">
        <div class="flex items-start justify-between">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold text-brand-700">
              MỚI NHẤT
            </div>
            <h3 class="mt-3 text-2xl font-bold text-gray-900">Workmate AI</h3>
            <p class="mt-1 text-sm text-gray-600">Trợ lý + Agent tự động hóa</p>
          </div>
          <div class="text-right text-xs text-gray-500" data-download-version="workmate">
            Đang tải…
          </div>
        </div>

        <div class="mt-6" data-download-target="workmate">
          <a
            href="https://github.com/AI-Workforce-Solutions/workmate-releases/releases/latest"
            target="_blank"
            rel="noopener"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-600 px-5 py-3 text-base font-semibold text-white transition hover:bg-brand-700"
            data-default-cta
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
            <span>Tải Workmate AI</span>
          </a>
        </div>

        <div class="mt-4 flex flex-wrap gap-2 text-xs" data-download-all="workmate">
          <a href="https://github.com/AI-Workforce-Solutions/workmate-releases/releases/latest" target="_blank" rel="noopener" class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-700 hover:bg-gray-200">macOS</a>
          <a href="https://github.com/AI-Workforce-Solutions/workmate-releases/releases/latest" target="_blank" rel="noopener" class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-700 hover:bg-gray-200">Windows</a>
          <a href="https://github.com/AI-Workforce-Solutions/workmate-releases/releases/latest" target="_blank" rel="noopener" class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-700 hover:bg-gray-200">Linux</a>
        </div>

        <p class="mt-5 text-xs text-gray-500">
          Nền tảng agentic AI thế hệ mới. Phát hành tháng 4/2026.
        </p>
      </article>

      <!-- CrawBot -->
      <article class="rounded-2xl border border-gray-200 bg-white p-8">
        <div class="flex items-start justify-between">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-700">
              ĐANG DÙNG ỔN ĐỊNH
            </div>
            <h3 class="mt-3 text-2xl font-bold text-gray-900">CrawBot</h3>
            <p class="mt-1 text-sm text-gray-600">Trợ lý AI dạng đồ họa</p>
          </div>
          <div class="text-right text-xs text-gray-500" data-download-version="crawbot">
            Đang tải…
          </div>
        </div>

        <div class="mt-6" data-download-target="crawbot">
          <a
            href="https://github.com/AI-Workforce-Solutions/crawbot-mike/releases/latest"
            target="_blank"
            rel="noopener"
            class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-gray-300 bg-white px-5 py-3 text-base font-semibold text-gray-700 transition hover:border-gray-400 hover:bg-gray-50"
            data-default-cta
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
            <span>Tải CrawBot</span>
          </a>
        </div>

        <div class="mt-4 flex flex-wrap gap-2 text-xs" data-download-all="crawbot">
          <a href="https://github.com/AI-Workforce-Solutions/crawbot-mike/releases/latest" target="_blank" rel="noopener" class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-700 hover:bg-gray-200">macOS</a>
          <a href="https://github.com/AI-Workforce-Solutions/crawbot-mike/releases/latest" target="_blank" rel="noopener" class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-700 hover:bg-gray-200">Windows</a>
          <a href="https://github.com/AI-Workforce-Solutions/crawbot-mike/releases/latest" target="_blank" rel="noopener" class="rounded-md bg-gray-100 px-2.5 py-1 text-gray-700 hover:bg-gray-200">Linux</a>
        </div>

        <p class="mt-5 text-xs text-gray-500">
          Sản phẩm trước đó của AIWS, đã có nhiều người dùng đang chạy thực tế.
        </p>
      </article>
    </div>

    <div class="mt-10 rounded-xl bg-amber-50 border border-amber-200 p-4 text-sm text-amber-900">
      <strong>Lưu ý:</strong> Các bản cài hiện tại <em>chưa được ký số</em> (code signing).
      Trên macOS có thể cần chuột phải → "Mở" để bỏ qua cảnh báo. Trên Windows SmartScreen bấm "More info" → "Run anyway".
      Bản ký số sẽ phát hành trong phiên bản tiếp theo.
    </div>
  </div>
</section>

<script>
  type Asset = { name: string; browser_download_url: string; size: number }
  type Release = { name: string; tag_name: string; published_at: string; assets: Asset[] }

  const REPOS = {
    workmate: "AI-Workforce-Solutions/workmate-releases",
    crawbot: "AI-Workforce-Solutions/crawbot-mike",
  }

  const OS_PATTERNS = {
    mac: [/mac/i, /darwin/i, /dmg$/i],
    win: [/win/i, /windows/i, /\.exe$/i, /\.msi$/i],
    linux: [/linux/i, /appimage$/i, /\.deb$/i, /\.rpm$/i],
  }

  function detectOS(): "mac" | "win" | "linux" | null {
    const ua = navigator.userAgent.toLowerCase()
    if (ua.includes("mac")) return "mac"
    if (ua.includes("win")) return "win"
    if (ua.includes("linux")) return "linux"
    return null
  }

  function detectArch(): "arm64" | "x64" {
    const ua = navigator.userAgent.toLowerCase()
    if (ua.includes("arm64") || ua.includes("aarch64")) return "arm64"
    if (navigator.userAgent.includes("Mac") && (navigator as any).userAgentData?.architecture === "arm") return "arm64"
    return "x64"
  }

  function pickAsset(assets: Asset[], os: "mac" | "win" | "linux", arch: "arm64" | "x64"): Asset | null {
    const osPatterns = OS_PATTERNS[os]
    const osCandidates = assets.filter((a) => osPatterns.some((p) => p.test(a.name)))
    if (osCandidates.length === 0) return null

    // Prefer arch match
    const archPat = arch === "arm64" ? /(arm64|aarch64)/i : /(x64|x86[_-]?64|amd64)/i
    const archMatch = osCandidates.find((a) => archPat.test(a.name))
    if (archMatch) return archMatch

    // Prefer non-blockmap / non-yml
    const installer = osCandidates.find((a) => !/(blockmap|\.yml|\.json)$/i.test(a.name))
    return installer ?? osCandidates[0]
  }

  function formatDate(iso: string): string {
    const d = new Date(iso)
    return d.toLocaleDateString("vi-VN", { year: "numeric", month: "2-digit", day: "2-digit" })
  }

  async function hydrate(key: keyof typeof REPOS) {
    const repo = REPOS[key]
    const cacheKey = `dl-${key}`
    const cacheTtl = 5 * 60 * 1000

    let release: Release | null = null
    const cached = localStorage.getItem(cacheKey)
    if (cached) {
      try {
        const { ts, data } = JSON.parse(cached)
        if (Date.now() - ts < cacheTtl) release = data
      } catch {}
    }

    if (!release) {
      try {
        const res = await fetch(`https://api.github.com/repos/${repo}/releases/latest`)
        if (!res.ok) throw new Error(`HTTP ${res.status}`)
        release = await res.json()
        localStorage.setItem(cacheKey, JSON.stringify({ ts: Date.now(), data: release }))
      } catch (e) {
        const versionEl = document.querySelector(`[data-download-version="${key}"]`)
        if (versionEl) versionEl.textContent = "—"
        return
      }
    }

    if (!release) return

    // Update version display
    const versionEl = document.querySelector(`[data-download-version="${key}"]`)
    if (versionEl) {
      versionEl.innerHTML = `
        <div class="font-mono font-semibold text-gray-700">${release.tag_name}</div>
        <div>${formatDate(release.published_at)}</div>
      `
    }

    // Update main CTA if OS detected
    const os = detectOS()
    const arch = detectArch()
    const targetEl = document.querySelector(`[data-download-target="${key}"] [data-default-cta]`) as HTMLAnchorElement | null
    if (os && targetEl) {
      const asset = pickAsset(release.assets, os, arch)
      if (asset) {
        targetEl.href = asset.browser_download_url
        const osLabel = { mac: "macOS", win: "Windows", linux: "Linux" }[os]
        const productLabel = key === "workmate" ? "Workmate AI" : "CrawBot"
        const span = targetEl.querySelector("span")
        if (span) span.textContent = `Tải ${productLabel} cho ${osLabel}`
      }
    }

    // Update per-OS links
    const allEl = document.querySelector(`[data-download-all="${key}"]`)
    if (allEl) {
      const osLinks = allEl.querySelectorAll("a")
      const osMap: Array<"mac" | "win" | "linux"> = ["mac", "win", "linux"]
      osLinks.forEach((link, i) => {
        const asset = pickAsset(release!.assets, osMap[i], arch)
        if (asset) link.setAttribute("href", asset.browser_download_url)
      })
    }
  }

  hydrate("workmate")
  hydrate("crawbot")
</script>
